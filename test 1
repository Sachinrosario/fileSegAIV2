function sbStartTimer(){_sbStart=Date.now();if(_sbTimer)clearInterval(_sbTimer);_sbTimer=setInterval(()=>{const s=Math.floor((Date.now()-_sbStart)/1000);document.getElementById('sbElapsed').textContent=`${String(Math.floor(s/60)).padStart(2,'0')}:${String(s%60).padStart(2,'0')}`;document.getElementById('sbSpeed').textContent=s>0?`${(_sbDone/s).toFixed(1)} f/s`:'0.0 f/s';},1000);}
function sbStopTimer(){if(_sbTimer){clearInterval(_sbTimer);_sbTimer=null;}}
function showToast(msg,type='warn'){const c=document.getElementById('toast-container');const t=document.createElement('div');t.className=`toast${type==='merge'?' merge':''}`;t.innerHTML=`<strong>${type==='merge'?'🔀 Folder Merged':'⚠️ Quota Alert'}</strong>${msg}`;c.appendChild(t);setTimeout(()=>{t.style.opacity='0';t.style.transform='translateX(120%)';t.style.transition='.3s';setTimeout(()=>t.remove(),300);},type==='merge'?4000:7000);}
