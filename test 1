  const sysPrompt = `You are an expert archivist who classifies documents by reading and understanding their actual content and subject matter.

EXISTING FOLDERS FOR THIS FILE TYPE (.${ext.toLowerCase()} files):
${existingBlock}

════════════════════════════════════════
