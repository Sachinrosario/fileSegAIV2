// ══════════════════════════════════════════════════════════════════════════════
// ████  PROPER CONTENT EXTRACTION ENGINE  ████
// ══════════════════════════════════════════════════════════════════════════════

// Snap a char position outward to a clean word boundary (never cuts mid-word)
function snapWord(text, pos, direction) {
  if (pos <= 0) return 0;
  if (pos >= text.length) return text.length;
  if (direction === 'back') {
    // Walk left until we hit whitespace or start
    while (pos > 0 && !/\s/.test(text[pos])) pos--;
    // Trim any trailing whitespace
    while (pos > 0 && /\s/.test(text[pos - 1])) pos--;
    return pos;
  } else {
    // Walk right until we hit whitespace or end
    while (pos < text.length && !/\s/.test(text[pos])) pos++;
    // Skip leading whitespace
    while (pos < text.length && /\s/.test(text[pos])) pos++;
    return pos;
  }
}

// Front-weighted strategic sampling: 60% start + 28% middle + 12% end
// Every slice snaps to word boundaries — no incomplete words ever.
function strategicSample(text, maxChars) {
  if (text.length <= maxChars) return text;

  const sRaw = Math.floor(maxChars * 0.60);
  const mRaw = Math.floor(maxChars * 0.28);
  const eRaw = maxChars - sRaw - mRaw;

  // ── Start slice: snap back to nearest word end ──
  const sEnd = snapWord(text, sRaw, 'back');
  const startChunk = text.slice(0, sEnd);

  // ── Middle slice: begin and end both snapped ──
  const mp     = Math.floor(text.length / 2);
  const mStart = snapWord(text, mp, 'forward');
  const mEnd   = snapWord(text, mStart + mRaw, 'back');
  const midChunk = text.slice(mStart, mEnd);

  // ── End slice: start from a clean word boundary ──
  const eStart = snapWord(text, text.length - eRaw, 'forward');
  const endChunk = text.slice(eStart);

  return (
    startChunk +
    '\n\n[── MIDDLE SAMPLE ──]\n' + midChunk +
    '\n\n[── END SAMPLE ──]\n' + endChunk +
    `\n\n[${text.length.toLocaleString()} total chars → ${maxChars.toLocaleString()} sampled across 3 sections]`
  );
}

function buf2b64(buf) {
  let o=''; const b = new Uint8Array(buf);
  for (let i=0; i<b.length; i+=8192) o += String.fromCharCode(...b.slice(i,i+8192));
  return btoa(o);
}

// ── PDF: PDF.js — extracts actual text layer, page by page ──────────────────
async function extractPDF(file, maxChars) {
  if (typeof pdfjsLib === 'undefined') {
    // Graceful fallback: send raw PDF bytes to API
    const cap = Math.min(file.size, 3 * 1024 * 1024);
    const b64 = buf2b64(await file.slice(0, cap).arrayBuffer());
    return { contentBlock: '[PDF.js not loaded — sending raw PDF bytes to API]',
             method: 'pdf-raw-fallback', isImage:false, isPDF:true, b64, mime:'application/pdf' };
  }

  const ab  = await file.arrayBuffer();
  const pdf = await pdfjsLib.getDocument({ data: ab }).promise;
  const total = pdf.numPages;

  // Smart page selection: all pages if small, sampled if large
  let pageNums;
  if (total <= 20) {
    pageNums = Array.from({length: total}, (_,i) => i+1);
  } else {
    const mid   = Math.floor(total / 2);
    const front = Array.from({length: Math.min(10, total)}, (_,i) => i+1);
    const centre= [mid-1, mid, mid+1].filter(n => n>=1 && n<=total);
    const tail  = [total-2, total-1, total].filter(n => n>=1 && n<=total);
    pageNums    = [...new Set([...front,...centre,...tail])].sort((a,b)=>a-b);
  }

  const pages = [];
  for (const n of pageNums) {
    const page    = await pdf.getPage(n);
    const content = await page.getTextContent();
    // Reconstruct reading order using Y position buckets
    const buckets = {};
    for (const item of content.items) {
      const y = Math.round(item.transform[5] / 5) * 5; // 5px buckets
      if (!buckets[y]) buckets[y] = [];
      buckets[y].push(item.str);
    }
    const pageText = Object.keys(buckets)
      .map(Number).sort((a,b) => b-a)  // descending y = top to bottom
      .map(y => buckets[y].join(' '))
      .join('\n').replace(/\n{3,}/g, '\n\n').trim();

    if (pageText) pages.push(`[Page ${n} of ${total}]\n${pageText}`);
  }

  const full = pages.join('\n\n');
  return {
    contentBlock: full
      ? strategicSample(full, maxChars)
      : '[PDF parsed but no text layer found — likely a scanned image PDF]',
    method: `PDF.js — ${pageNums.length}/${total} pages · ${full.length.toLocaleString()} chars extracted`,
    isImage:false, isPDF:false, b64:null, mime:null
  };
}

// ── DOCX: mammoth.js — clean paragraphs, zero XML noise ─────────────────────
async function extractDOCX(file, maxChars) {
  if (typeof mammoth === 'undefined') {
    return { contentBlock: '[mammoth.js not loaded — DOCX content unavailable]',
             method: 'docx-no-library', isImage:false, isPDF:false, b64:null, mime:null };
  }
  const ab     = await file.arrayBuffer();
  const result = await mammoth.extractRawText({ arrayBuffer: ab });
  const text   = result.value || '';

  return {
    contentBlock: text
      ? strategicSample(text, maxChars)
      : '[DOCX parsed but document appears empty]',
    method: `mammoth.js — ${text.length.toLocaleString()} chars · ${result.messages?.length||0} parse warnings`,
    isImage:false, isPDF:false, b64:null, mime:null
  };
}

// ── XLSX/XLS/ODS: SheetJS — every cell value, every sheet ───────────────────
async function extractXLSX(file, maxChars) {
  if (typeof XLSX === 'undefined') {
    return { contentBlock: '[SheetJS not loaded — spreadsheet content unavailable]',
             method: 'xlsx-no-library', isImage:false, isPDF:false, b64:null, mime:null };
  }
  const ab = await file.arrayBuffer();
  const wb = XLSX.read(ab, { type:'array', cellText:true, cellDates:true });

  const parts = [
    `Spreadsheet: ${file.name}`,
    `Sheets (${wb.SheetNames.length}): ${wb.SheetNames.join(', ')}`
  ];

  let totalRows = 0;
  for (const name of wb.SheetNames.slice(0, 6)) {
    const ws  = wb.Sheets[name];
    const csv = XLSX.utils.sheet_to_csv(ws, { blankrows:false, skipHidden:true });
    const rows = csv.split('\n')
      .map(r => r.trim())
      .filter(r => r && !/^,+$/.test(r)); // skip blank/all-comma rows
    totalRows += rows.length;
    const preview = rows.slice(0, 80);
    parts.push(`\n[Sheet: "${name}" — ${rows.length} rows]\n${preview.join('\n')}`);
    if (rows.length > 80) parts.push(`  … (${rows.length - 80} more rows not shown)`);
  }

  const full = parts.join('\n');
  return {
    contentBlock: strategicSample(full, maxChars),
    method: `SheetJS — ${wb.SheetNames.length} sheets · ~${totalRows} data rows extracted`,
    isImage:false, isPDF:false, b64:null, mime:null
  };
}

// ── CSV: native parse — headers + structured rows ───────────────────────────
async function extractCSV(file, maxChars) {
  const raw   = await file.text();
  const lines = raw.split('\n').map(l=>l.trim()).filter(Boolean);
  const hdr   = lines[0] || '(no headers)';
  const rows  = lines.slice(1, 61);
  const text  = `CSV Dataset: ${file.name}\nColumns: ${hdr}\nTotal rows: ${lines.length-1}\n\nSample:\n${rows.join('\n')}`;
  return {
    contentBlock: strategicSample(text, maxChars),
    method: `CSV native — ${hdr.split(',').length} columns · ${lines.length-1} rows`,
    isImage:false, isPDF:false, b64:null, mime:null
  };
}

// ── Plain text / code ────────────────────────────────────────────────────────
async function extractText(file, maxChars) {
  const raw = await file.text();
  return {
    contentBlock: strategicSample(raw, maxChars),
    method: raw.length > maxChars
      ? `text sampled — ${fmtSize(raw.length)} → ${maxChars.toLocaleString()} chars`
      : `text full-read — ${fmtSize(raw.length)}`,
    isImage:false, isPDF:false, b64:null, mime:null
  };
}

// ── Images: base64 for visual analysis ──────────────────────────────────────
async function extractImage(file, ext, isPro) {
  const cap  = (isPro ? 8 : 3) * 1024 * 1024;
  const mime = IMG_MIME[ext] || 'image/jpeg';
  if (file.size <= cap) {
    return {
      contentBlock: `[Image — sent for direct visual analysis · ${fmtSize(file.size)}]`,
      method: `image visual-analysis (${fmtSize(file.size)})`,
      isImage:true, isPDF:false, b64: buf2b64(await file.arrayBuffer()), mime
    };
  }
  return {
    contentBlock: `[Image too large (${fmtSize(file.size)}) — classifying from filename]`,
    method: 'image-too-large', isImage:false, isPDF:false, b64:null, mime:null
  };
}

// ── Master dispatcher ────────────────────────────────────────────────────────
async function extractFileContent(file, isPro) {
  const maxChars = isPro ? 15000 : 8000;
  const ext = (file.name.includes('.') ? file.name.split('.').pop() : '').toLowerCase();
  try {
    if (ext === 'pdf')                              return await extractPDF(file, maxChars);
    if (['docx','doc','odt','rtf'].includes(ext))   return await extractDOCX(file, maxChars);
    if (['xlsx','xls','xlsm','ods'].includes(ext))  return await extractXLSX(file, maxChars);
    if (ext === 'csv')                              return await extractCSV(file, maxChars);
    if (TEXT_EXTS.has(ext))                         return await extractText(file, maxChars);
    if (IMG_EXTS.has(ext))                          return await extractImage(file, ext, isPro);
    if (['pptx','ppt','odp'].includes(ext))
      return { contentBlock:`[Presentation — ${fmtSize(file.size)} · classifying from filename]`,
               method:'pptx-metadata-only', isImage:false, isPDF:false, b64:null, mime:null };
    return { contentBlock:`[Binary .${ext} file — no text extraction available]`,
             method:'unsupported-binary', isImage:false, isPDF:false, b64:null, mime:null };
  } catch(e) {
    return { contentBlock:`[Extraction error: ${e.message}]`,
             method:`error`, isImage:false, isPDF:false, b64:null, mime:null };
  }
}

// ══════════════════════════════════════════════════════════════════════════════
// FOLDER DEDUPLICATOR
// ══════════════════════════════════════════════════════════════════════════════
function tokenize(s) {
  return s.toLowerCase().replace(/[_\-]/g,' ').split(/\s+/)
          .filter(w => w.length>1 && !STOP_WORDS.has(w));
}
function jaccard(a, b) {
  const ta=new Set(tokenize(a)), tb=new Set(tokenize(b));
  if (!ta.size && !tb.size) return 1;
  if (!ta.size || !tb.size) return 0;
  let i=0; ta.forEach(w=>{ if(tb.has(w))i++; });
  return i / (ta.size+tb.size-i);
}
function isAcronym(s) { return /^[A-Z]{2,8}(\s|$)/.test(s.trim()); }

function resolveCategory(proposed, ext) {
  if (!proposed) return 'Uncategorized Content';
  const thr = parseFloat(document.getElementById('simThreshold').value);
  if (!subCatMemory[ext]) subCatMemory[ext] = [];
  const existing = subCatMemory[ext];

  const exact = existing.find(e => e.name.toLowerCase()===proposed.toLowerCase());
  if (exact) { exact.count++; return exact.name; }

  if (isAcronym(proposed)) { existing.push({name:proposed,count:1}); return proposed; }

  let best=null, bestScore=0;
  for (const e of existing) {
    if (isAcronym(e.name)) continue;
    const s = jaccard(proposed, e.name);
    if (s > bestScore) { bestScore=s; best=e; }
  }
  if (best && bestScore >= thr) {
    best.count++;
    totalMerges++;
    document.getElementById('sbMerges').textContent = totalMerges;
    log('merge', `"${proposed}" → merged into "${best.name}" (${(bestScore*100).toFixed(0)}% match)`);
    showToast(`Merged: <strong>"${proposed}"</strong> → <strong>"${best.name}"</strong>`, 'merge');
    return best.name;
  }

  existing.push({name:proposed, count:1});
  return proposed;
}

