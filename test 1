════════════════════════════════════════
Read the file content carefully. Assign ONE descriptive folder name that captures:
— The SUBJECT MATTER (what topic or domain?)
— The DOCUMENT TYPE (textbook, research paper, invoice, dataset, syllabus, field report, etc.)
— Any SPECIFIC ENTITY or PROJECT (institution, species, acronym, product name)

NAMING STANDARD:
• 3 to 6 words · Title Case · Specific and descriptive
• Good examples:
    "Botany Research Field Studies"
    "Ficus Benghalensis Growth Analysis"
    "NAAC Accreditation Reports"
    "University Semester Course Syllabi"
    "Quarterly Financial Statements"
    "Patient Medical Case Records"
    "Software Architecture Design"
    "Environmental Impact Assessments"
    "UUCMS Student Enrollment Data"

DECISION ORDER:
1. READ CONTENT — ignore the filename, understand what the document actually IS
2. REUSE EXACT — if content clearly fits an existing folder above, return it CHARACTER-FOR-CHARACTER
3. ACRONYMS ARE SACRED — if an institutional code appears (UUCMS, NAAC, ESG, DHI, WHO), include it
4. CREATE THOUGHTFULLY — new folder only if nothing fits; prefer slightly broader over too narrow

NEVER RESPOND WITH: "Unclassified" "Unknown" "Miscellaneous" "Other" "General" "Various" "Documents" "Files" "Folder" "Category" "Data" "Content" "Material"${
    customArray.length ? `\n\nROUTER MODE: You MUST pick from: [${customArray.join(', ')}]. Choose the best fit.` : ''
  }

Respond with ONLY the folder name. No quotes, no period at end, no explanation.`;

  let url='', hdrs={}, body={};

  if (provider==='anthropic') {
    url  = 'https://api.anthropic.com/v1/messages';
    hdrs = {'Content-Type':'application/json','x-api-key':apiKey,
            'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-ipc':'true'};
    const c = [];
    if (content.isImage) c.push({type:'image',source:{type:'base64',media_type:content.mime,data:content.b64}});
    else if (content.isPDF) c.push({type:'document',source:{type:'base64',media_type:'application/pdf',data:content.b64}});
    c.push({type:'text',text:userMsg});
    body = {model:'claude-haiku-4-5-20251001',max_tokens:80,temperature:tempVal,
            system:sysPrompt,messages:[{role:'user',content:c}]};

  } else if (provider==='openai') {
    url  = 'https://api.openai.com/v1/chat/completions';
    hdrs = {'Content-Type':'application/json','Authorization':`Bearer ${apiKey}`};
    const c = [];
    if (content.isImage) c.push({type:'image_url',image_url:{url:`data:${content.mime};base64,${content.b64}`}});
    c.push({type:'text',text:userMsg});
    body = {model:'gpt-4o-mini',max_tokens:80,temperature:tempVal,
            messages:[{role:'system',content:sysPrompt},{role:'user',content:c}]};

  } else { // google
    url  = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${apiKey}`;
    hdrs = {'Content-Type':'application/json'};
    const parts = [];
    if (content.isImage||content.isPDF) parts.push({inlineData:{mimeType:content.mime,data:content.b64}});
    parts.push({text:userMsg});
    body = {systemInstruction:{parts:[{text:sysPrompt}]},
            contents:[{role:'user',parts}],
            generationConfig:{maxOutputTokens:80,temperature:tempVal}};
  }

  let resp, retries=5, delay=10000;
  while (retries >= 0) {
    resp = await fetch(url, {method:'POST',headers:hdrs,body:JSON.stringify(body)});
    if (resp.status===429 && retries>0) {
      retries--; log('warn',`Rate limited — retry in ${delay/1000}s`);
      await sleep(delay); delay=Math.min(delay*2,60000); continue;
    }
    break;
  }
  if (!resp.ok) { const e=await resp.json().catch(()=>({})); throw new Error(e.error?.message||`HTTP ${resp.status}`); }

  const data = await resp.json();
  let raw = '';
  if (provider==='anthropic') raw=data.content?.[0]?.text||'';
  else if (provider==='openai') raw=data.choices?.[0]?.message?.content||'';
  else raw=data.candidates?.[0]?.content?.parts?.[0]?.text||'';

  // Sanitize
  let cat = raw
    .replace(/[<>:"/\\|?*\x00-\x1f]/g,'')
    .replace(/[\r\n]+/g,' ').replace(/\s+/g,' ')
    .replace(/^["'\s]+|["'\s.]+$/g,'').trim();

  if (customArray.length) {
    const m = customArray.find(c =>
      c.toLowerCase()===cat.toLowerCase() ||
      cat.toLowerCase().includes(c.toLowerCase()) ||
      c.toLowerCase().includes(cat.toLowerCase()));
    cat = m || customArray[0];
  }

  const BAD = new Set(['unclassified','unknown','none','miscellaneous','other','general',
    'various','documents','files','folder','category','data','content','material','items','mixed']);
  const words = cat.toLowerCase().split(' ');
  if (!cat || (words.length<=1 && BAD.has(words[0]))) cat = 'Uncategorized Content';
  return cat;
}

