// FILE SYSTEM HELPERS
// ══════════════════════════════════════════════════════════════════════════════
const activeWrites = new Set();
async function safeWrite(dir, file) {
  let target=file.name, att=0;
  while(att<50) {
    if(activeWrites.has(target)){att++;target=renameFn(file.name,att);continue;}
    try{ await dir.getFileHandle(target); att++;target=renameFn(file.name,att); }
    catch(e){
      if(e.name==='NotFoundError'){
        activeWrites.add(target);
        try{const fh=await dir.getFileHandle(target,{create:true});const ws=await fh.createWritable();await file.stream().pipeTo(ws);activeWrites.delete(target);return target;}
        catch(we){activeWrites.delete(target);throw we;}
      }
      throw e;
    }
  }
  throw new Error('Max renames exceeded');
}
function renameFn(n,i){const d=n.lastIndexOf('.');return d>0?n.slice(0,d)+`_(${i})`+n.slice(d):n+`_(${i})`;}
async function getOrCreateDir(p,n){return p.getDirectoryHandle(n,{create:true});}
async function processBatch(items,limit,fn){
  const running=new Set();
  for(const item of items){const p=fn(item).finally(()=>running.delete(p));running.add(p);if(running.size>=limit)await Promise.race(running);}
  await Promise.all(running);
}
const sleep = ms => new Promise(r=>setTimeout(r,ms));

