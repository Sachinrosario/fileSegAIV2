<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FILE SEGREGATOR AI - MASTER</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Barlow+Condensed:wght@300;400;600;700;900&display=swap" rel="stylesheet">

<!-- ══ PROPER DOCUMENT PARSERS (CDN) ════════════════════════════════════════ -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/mammoth/1.6.0/mammoth.browser.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<style>
  :root {
    --bg:#0a0c0f; --surface:#0f1318; --panel:#131820; --border:#1e2a38;
    --accent:#00d4ff; --accent2:#ff6b35; --accent3:#39ff14;
    --warn:#ffd700; --ai:#b06aff; --text:#c8d8e8; --muted:#4a5a6a;
    --mono:'Share Tech Mono',monospace; --display:'Barlow Condensed',sans-serif;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  body{background:var(--bg);color:var(--text);font-family:var(--mono);font-size:13px;min-height:100vh;overflow-x:hidden;padding-bottom:36px;}
  body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,212,255,.012) 2px,rgba(0,212,255,.012) 4px);pointer-events:none;z-index:1000;}
  .header{padding:14px 28px 12px;border-bottom:1px solid var(--border);display:flex;align-items:flex-end;gap:20px;background:linear-gradient(180deg,#0d1520 0%,var(--bg) 100%);}
  .logo{font-family:var(--display);font-size:36px;font-weight:900;letter-spacing:6px;color:var(--accent);text-shadow:0 0 30px rgba(0,212,255,.4);line-height:1;}
  .logo span{color:var(--accent2);}
  .logo sup{font-size:14px;letter-spacing:2px;color:var(--ai);text-shadow:0 0 12px var(--ai);vertical-align:super;}
  .tagline{font-family:var(--display);font-size:12px;font-weight:300;letter-spacing:4px;color:var(--muted);text-transform:uppercase;margin-bottom:3px;}
  .hstatus{margin-left:auto;display:flex;align-items:center;gap:10px;font-size:11px;color:var(--muted);}
  .sdot{width:8px;height:8px;border-radius:50%;background:var(--muted);}
  .sdot.on{background:var(--accent3);box-shadow:0 0 8px var(--accent3);animation:blink 1.5s infinite;}
  @keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

  /* Parser status bar */
  .parser-bar{background:#060a0d;border-bottom:1px solid var(--border);padding:6px 22px;display:flex;align-items:center;gap:16px;font-size:10px;flex-wrap:wrap;}
  .pbar-label{color:var(--muted);letter-spacing:2px;text-transform:uppercase;flex-shrink:0;font-family:var(--display);font-weight:700;}
  .plib{display:flex;align-items:center;gap:6px;padding:2px 10px;border:1px solid var(--border);}
  .plib-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;}
  .plib-dot.loading{background:var(--warn);animation:blink .8s infinite;}
  .plib-dot.ok{background:var(--accent3);box-shadow:0 0 5px var(--accent3);}
  .plib-dot.err{background:#ff4444;}
  .plib-name{font-size:10px;}
  .plib-name.ok{color:var(--accent3);}
  .plib-name.err{color:#ff4444;}
  .plib-name.loading{color:var(--warn);}

  .wrap{display:flex;flex-direction:column;gap:1px;background:var(--border);}
  .prow{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border);}
  .panel{background:var(--surface);padding:18px 22px;}
  .plabel{font-family:var(--display);font-size:11px;font-weight:700;letter-spacing:4px;text-transform:uppercase;color:var(--muted);margin-bottom:12px;display:flex;align-items:center;gap:8px;}
  .plabel::after{content:'';flex:1;height:1px;background:var(--border);}
  .plabel.ai-label{color:var(--ai);}
  .plabel.ai-label::after{background:rgba(176,106,255,.3);}
  input[type=file]{display:none;}
  .fbox{background:var(--panel);border:1px solid var(--border);padding:9px 13px;font-family:var(--mono);font-size:11px;color:var(--muted);min-height:36px;display:flex;align-items:center;gap:8px;word-break:break-all;cursor:pointer;transition:.2s;margin-bottom:8px;}
  .fbox:hover{border-color:var(--accent);}
  .fbox.src-set{color:var(--text);border-color:var(--accent);}
  .fbox.dest-set{color:var(--text);border-color:var(--accent2);}
  .api-input{background:var(--panel);border:1px solid var(--border);padding:9px 13px;font-family:var(--mono);font-size:12px;color:var(--text);width:100%;outline:none;transition:.2s;letter-spacing:2px;}
  .api-input:focus{border-color:var(--ai);box-shadow:0 0 0 1px var(--ai);}
  .api-input::placeholder{color:var(--muted);letter-spacing:0;}
  select.api-input{appearance:none;cursor:pointer;}
  .hint{font-size:10px;color:var(--muted);margin-top:6px;display:flex;gap:6px;}
  .hint span:first-child{color:var(--accent);}
  .btn{padding:9px 18px;border:none;cursor:pointer;font-family:var(--display);font-size:13px;font-weight:700;letter-spacing:3px;text-transform:uppercase;transition:.15s;}
  .btn-src{border:1px solid var(--accent);color:var(--accent);background:transparent;}
  .btn-src:hover{background:var(--accent);color:var(--bg);box-shadow:0 0 20px rgba(0,212,255,.4);}
  .btn-dest{border:1px solid var(--accent2);color:var(--accent2);background:transparent;}
  .btn-dest:hover{background:var(--accent2);color:var(--bg);box-shadow:0 0 20px rgba(255,107,53,.4);}
  .btn-scan{border:1px solid var(--accent3);color:var(--accent3);background:transparent;margin-top:8px;}
  .btn-scan:hover:not(:disabled){background:rgba(57,255,20,.1);}
  .btn-scan:disabled{opacity:.35;cursor:not-allowed;}
  .btn-go{background:var(--accent3);color:var(--bg);border:none;font-size:15px;padding:12px 32px;box-shadow:0 0 20px rgba(57,255,20,.35);}
  .btn-go:hover:not(:disabled){box-shadow:0 0 40px rgba(57,255,20,.65);transform:translateY(-1px);}
  .btn-go:disabled{background:var(--muted);box-shadow:none;cursor:not-allowed;transform:none;color:#333;}
  .btn-reset{border:1px solid var(--muted);color:var(--muted);background:transparent;font-size:11px;padding:7px 14px;}
  .btn-reset:hover{border-color:var(--text);color:var(--text);}
  .note{background:rgba(255,215,0,.05);border-left:3px solid var(--warn);padding:7px 13px;font-size:11px;color:var(--warn);display:flex;gap:8px;line-height:1.4;}
  .note.green{background:rgba(57,255,20,.05);border-color:var(--accent3);color:var(--accent3);}
  .note.ai{background:rgba(176,106,255,.07);border-color:var(--ai);color:var(--ai);}
  .ai-panel{background:var(--surface);padding:16px 22px;border-bottom:1px solid var(--border);}
  .ai-row{display:flex;align-items:flex-start;gap:24px;flex-wrap:wrap;}
  .ai-key-wrap{flex:2;min-width:320px;}
  .ai-options-wrap{flex:2;min-width:380px;}
  .ai-toggle-wrap{display:flex;align-items:center;gap:10px;white-space:nowrap;}
  .toggle{position:relative;width:42px;height:22px;flex-shrink:0;}
  .toggle input{opacity:0;width:0;height:0;}
  .tslider{position:absolute;inset:0;background:var(--border);border-radius:11px;cursor:pointer;transition:.25s;}
  .tslider::before{content:'';position:absolute;width:16px;height:16px;left:3px;top:3px;background:var(--muted);border-radius:50%;transition:.25s;}
  input:checked+.tslider{background:var(--ai);box-shadow:0 0 8px rgba(176,106,255,.5);}
  input:checked+.tslider::before{transform:translateX(20px);background:#fff;}
  .toggle-label{font-family:var(--display);font-size:12px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--muted);}
  .toggle-label.on{color:var(--ai);}
  .ai-model-badge{background:rgba(176,106,255,.1);border:1px solid rgba(176,106,255,.3);padding:3px 10px;font-size:10px;letter-spacing:2px;color:var(--ai);white-space:nowrap;}
  .show-key-btn{background:none;border:none;color:var(--muted);cursor:pointer;font-size:11px;padding:0;text-decoration:underline;font-family:var(--mono);}
  .show-key-btn:hover{color:var(--text);}
  .quota-box{background:#070a0d;border:1px solid var(--border);padding:8px 12px;font-size:10px;color:var(--muted);margin-top:8px;line-height:1.5;}
  .quota-box span{color:var(--text);}
  .summary{background:var(--surface);padding:18px 22px;display:none;flex-direction:column;gap:14px;}
  .summary.on{display:flex;}
  .two-col{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border);border:1px solid var(--border);}
  .col-block{background:var(--panel);padding:14px 18px;}
  .st-label{font-family:var(--display);font-size:10px;letter-spacing:3px;color:var(--muted);text-transform:uppercase;margin-bottom:6px;}
  .st-val{font-family:var(--display);font-size:28px;font-weight:900;color:var(--accent);line-height:1;}
  .st-val.d{color:var(--accent2);}
  .st-row{display:flex;gap:24px;margin-top:8px;}
  .cats-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(145px,1fr));gap:8px;}
  .ccard{background:var(--panel);border:1px solid var(--border);padding:9px 13px;display:flex;flex-direction:column;gap:3px;position:relative;overflow:hidden;}
  .ccard::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--ext-color,var(--accent));}
  .ccat{font-family:var(--display);font-size:11px;font-weight:700;letter-spacing:2px;color:var(--text);}
  .cicon{font-size:16px;margin-bottom:1px;}
  .ccount{font-family:var(--display);font-size:22px;font-weight:900;color:var(--accent);line-height:1;}
  .csize{font-size:10px;color:var(--muted);}
  .flist-wrap{background:var(--panel);border:1px solid var(--border);max-height:150px;overflow-y:auto;}
  .flist-wrap::-webkit-scrollbar{width:4px;}
  .flist-wrap::-webkit-scrollbar-thumb{background:var(--muted);}
  .frow{display:flex;gap:10px;padding:5px 12px;border-bottom:1px solid rgba(30,42,56,.5);font-size:11px;align-items:center;}
  .frow:last-child{border-bottom:none;}
  .fname{color:var(--text);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
  .fsize{color:var(--muted);flex-shrink:0;min-width:60px;text-align:right;}
  .fcat{flex-shrink:0;font-size:10px;padding:1px 6px;background:var(--border);color:var(--muted);}
  .actions{display:flex;align-items:center;gap:12px;padding-top:12px;border-top:1px solid var(--border);}
  .ainfo{color:var(--muted);font-size:11px;margin-left:auto;}
  .logpanel{background:var(--surface);display:none;flex-direction:column;}
  .logpanel.on{display:flex;}
  .loghdr{padding:9px 22px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px;background:var(--panel);flex-wrap:wrap;}
  .logtitle{font-family:var(--display);font-size:11px;font-weight:700;letter-spacing:4px;color:var(--muted);text-transform:uppercase;}
  .phase-badges{display:flex;gap:6px;}
  .phase-badge{font-family:var(--display);font-size:10px;font-weight:700;letter-spacing:2px;padding:2px 8px;text-transform:uppercase;opacity:.4;transition:.3s;}
  .phase-badge.active{opacity:1;}
  .phase-badge.p1{border:1px solid var(--accent);color:var(--accent);}
  .phase-badge.p1.active{background:rgba(0,212,255,.1);}
  .phase-badge.p2{border:1px solid var(--ai);color:var(--ai);}
  .phase-badge.p2.active{background:rgba(176,106,255,.1);}
  .pbwrap{flex:1;height:4px;background:var(--border);overflow:hidden;min-width:80px;}
  .pb{height:100%;width:0%;transition:width .3s;background:linear-gradient(90deg,var(--accent3),var(--accent));}
  .ppct{font-size:11px;color:var(--accent3);min-width:36px;text-align:right;}
  .log-tree-wrap{display:grid;grid-template-columns:1fr 320px;gap:1px;background:var(--border);}
  .logout{overflow-y:auto;padding:12px 22px;font-size:11px;line-height:1.8;background:#070a0d;max-height:300px;}
  .logout::-webkit-scrollbar{width:4px;}
  .logout::-webkit-scrollbar-thumb{background:var(--muted);}
  .lline{display:flex;gap:10px;align-items:baseline;}
  .ltime{color:var(--muted);flex-shrink:0;}
  .lok{color:var(--accent3);}  .lerr{color:#ff4444;}  .linfo{color:var(--accent);}
  .lwarn{color:var(--warn);}   .lai{color:var(--ai);}  .lmerge{color:var(--accent2);}
  .lmsg{color:var(--text);}
  .tree-panel{background:#070a0d;overflow-y:auto;max-height:300px;padding:12px 14px;}
  .tree-panel::-webkit-scrollbar{width:4px;}
  .tree-panel::-webkit-scrollbar-thumb{background:var(--muted);}
  .tree-hdr{font-family:var(--display);font-size:10px;font-weight:700;letter-spacing:3px;color:var(--muted);text-transform:uppercase;margin-bottom:8px;display:flex;align-items:center;gap:6px;}
  .tree-hdr::after{content:'';flex:1;height:1px;background:var(--border);}
  .tree-node{font-size:11px;line-height:1.7;font-family:var(--mono);}
  .tree-ext{color:var(--accent);font-weight:bold;}
  .tree-sub{color:var(--ai);padding-left:16px;}
  .tree-sub::before{content:'└─ ';color:var(--muted);}
  .tree-count{color:var(--muted);font-size:10px;margin-left:5px;}
  .done-banner{display:none;background:rgba(57,255,20,.08);border:1px solid var(--accent3);padding:10px 22px;text-align:center;font-family:var(--display);font-size:15px;font-weight:700;letter-spacing:4px;color:var(--accent3);}
  .done-banner.on{display:block;}
  .statusbar{position:fixed;bottom:0;left:0;right:0;height:32px;background:#080b0f;border-top:1px solid var(--border);display:flex;align-items:center;font-size:11px;font-family:var(--mono);z-index:500;overflow:hidden;}
  .sb-seg{display:flex;align-items:center;gap:7px;padding:0 14px;height:100%;border-right:1px solid var(--border);white-space:nowrap;flex-shrink:0;}
  .sb-label{color:var(--muted);letter-spacing:2px;font-size:10px;text-transform:uppercase;}
  .sb-val{color:var(--text);}
  .sb-val.accent{color:var(--accent);} .sb-val.accent2{color:var(--accent2);}
  .sb-val.green{color:var(--accent3);} .sb-val.warn{color:var(--warn);} .sb-val.ai{color:var(--ai);}
  .sb-phase{display:flex;align-items:center;gap:7px;padding:0 14px;height:100%;border-right:1px solid var(--border);}
  .sb-dot{width:6px;height:6px;border-radius:50%;background:var(--muted);flex-shrink:0;transition:background .3s;}
  .sb-dot.idle{background:var(--muted);}
  .sb-dot.loading{background:var(--accent);box-shadow:0 0 6px var(--accent);animation:blink 1s infinite;}
  .sb-dot.ready{background:var(--warn);box-shadow:0 0 6px var(--warn);}
  .sb-dot.copy,.sb-dot.classify,.sb-dot.done{background:var(--accent3);box-shadow:0 0 6px var(--accent3);}
  .sb-dot.classify{background:var(--ai);box-shadow:0 0 6px var(--ai);animation:blink .6s infinite;}
  .sb-plabel{font-family:var(--display);font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--muted);}
  .sb-plabel.ready{color:var(--warn);} .sb-plabel.copy,.sb-plabel.done{color:var(--accent3);}
  .sb-plabel.classify{color:var(--ai);}
  .sb-activity{flex:1;padding:0 14px;height:100%;display:flex;align-items:center;gap:8px;overflow:hidden;min-width:0;border-right:1px solid var(--border);}
  .sb-act-icon{font-size:12px;flex-shrink:0;}
  .sb-act-text{color:var(--muted);font-size:11px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
  .sb-act-text.active{color:var(--text);}
  #toast-container{position:fixed;top:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:10px;pointer-events:none;}
  .toast{background:var(--surface);border-left:4px solid var(--warn);color:var(--text);padding:12px 20px;box-shadow:0 4px 20px rgba(0,0,0,.5);animation:slideIn .3s ease-out;font-family:var(--mono);font-size:12px;line-height:1.5;pointer-events:auto;}
  .toast strong{color:var(--warn);display:block;margin-bottom:4px;font-family:var(--display);letter-spacing:2px;font-size:14px;text-transform:uppercase;}
  .toast.merge{border-left-color:var(--accent2);}  .toast.merge strong{color:var(--accent2);}
  @keyframes slideIn{from{transform:translateX(120%);opacity:0}to{transform:translateX(0);opacity:1}}
</style>
</head>
<body>
<div id="toast-container"></div>

<header class="header">
  <div>
    <div class="logo">FILE<span>SEG</span> <sup>MASTER</sup></div>
    <div class="tagline">Enterprise AI Segregation · Real Document Parsing · Smart Dedup</div>
  </div>
  <div class="hstatus"><div class="sdot" id="sdot"></div><span id="stxt">IDLE</span></div>
</header>

<!-- Parser status row -->
<div class="parser-bar">
  <span class="pbar-label">Parsers</span>
  <div class="plib">
    <div class="plib-dot loading" id="dot-pdf"></div>
    <span class="plib-name loading" id="lbl-pdf">PDF.js — loading…</span>
  </div>
  <div class="plib">
    <div class="plib-dot loading" id="dot-docx"></div>
    <span class="plib-name loading" id="lbl-docx">mammoth.js — loading…</span>
  </div>
  <div class="plib">
    <div class="plib-dot loading" id="dot-xlsx"></div>
    <span class="plib-name loading" id="lbl-xlsx">SheetJS — loading…</span>
  </div>
  <span style="color:var(--muted);font-size:10px;margin-left:auto;">Requires internet · CDN: cdnjs.cloudflare.com</span>
</div>

<div class="wrap">
  <div class="prow">
    <div class="panel">
      <div class="plabel">01 · Source Folder</div>
      <div class="fbox" id="srcBox" onclick="document.getElementById('srcInput').click()"><span>📂</span><span id="srcLabel">Click to select source folder</span></div>
      <input type="file" id="srcInput" webkitdirectory multiple onchange="onSrcChange(this)">
      <button class="btn btn-src" onclick="document.getElementById('srcInput').click()">▶ SELECT SOURCE FOLDER</button>
      <div class="hint"><span>ℹ</span><span>Recursively scanned. Source files are NEVER deleted.</span></div>
    </div>
    <div class="panel">
      <div class="plabel">02 · Destination Folder</div>
      <div class="fbox" id="destBox" onclick="pickDest()"><span>📁</span><span id="destLabel">Click to select destination folder</span></div>
      <button class="btn btn-dest" onclick="pickDest()">▶ SELECT DESTINATION FOLDER</button>
      <div class="hint"><span>ℹ</span><span>Generates Segregation_Report.txt upon completion.</span></div>
      <div style="margin-top:10px" class="note green"><span>✓</span><span>Files <strong>never deleted</strong> — copy only · Structure: DEST / [EXT] / [AI Category] / file</span></div>
    </div>
  </div>

  <div class="ai-panel">
    <div style="display:flex;align-items:center;gap:16px;margin-bottom:12px;flex-wrap:wrap;">
      <div class="plabel ai-label" style="margin-bottom:0;flex-shrink:0;">03 · AI Classification</div>
      <div class="ai-toggle-wrap">
        <label class="toggle"><input type="checkbox" id="aiToggle" onchange="onAiToggle()" checked><span class="tslider"></span></label>
        <span class="toggle-label on" id="toggleLabel">ENABLED</span>
      </div>
      <div class="ai-model-badge" id="modelBadge">gemini-2.5-flash</div>
      <div style="display:flex;align-items:center;gap:6px;font-size:10px;color:var(--muted);">
        <div id="apiDot" style="width:6px;height:6px;border-radius:50%;background:var(--muted);"></div>
        <span id="apiStatusText">No key entered</span>
      </div>
    </div>
    <div class="ai-row">
      <div class="ai-key-wrap">
        <div style="display:flex;gap:10px;margin-bottom:8px;align-items:flex-end;flex-wrap:wrap;">
          <div style="flex:1;min-width:120px;">
            <div style="font-size:10px;color:var(--muted);letter-spacing:2px;margin-bottom:5px;">PROVIDER</div>
            <select class="api-input" id="aiProvider" onchange="updateQuotaInfo()" style="padding:7px 10px;">
              <option value="google">Google (Gemini)</option>
              <option value="openai">OpenAI (GPT-4o-mini)</option>
              <option value="anthropic">Anthropic (Claude)</option>
            </select>
          </div>
          <div style="flex:0;min-width:90px;">
            <div style="font-size:10px;color:var(--muted);letter-spacing:2px;margin-bottom:5px;">PLAN TIER</div>
            <div class="ai-toggle-wrap" style="height:31px;background:var(--panel);border:1px solid var(--border);padding:0 8px;display:inline-flex;">
              <label class="toggle" style="transform:scale(0.85);margin-right:4px;"><input type="checkbox" id="tierToggle" onchange="updateQuotaInfo()"><span class="tslider"></span></label>
              <span class="toggle-label" id="tierLabel" style="font-size:11px;">FREE</span>
            </div>
          </div>
          <div style="flex:2;min-width:200px;">
            <div style="font-size:10px;color:var(--muted);letter-spacing:2px;margin-bottom:5px;">API KEY</div>
            <div style="display:flex;gap:8px;align-items:center;">
              <input class="api-input" type="password" id="apiKeyInput" placeholder="AIza..." oninput="onApiKeyChange()" autocomplete="off">
              <button class="show-key-btn" onclick="toggleKeyVis()" id="showKeyBtn">show</button>
            </div>
          </div>
