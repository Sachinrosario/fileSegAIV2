function treeAdd(ext, sub) {
  if (!treeState[ext]) treeState[ext]={};
  treeState[ext][sub] = (treeState[ext][sub]||0)+1;
  const out = document.getElementById('treeOut');
  let html = '';
  for (const e of Object.keys(treeState).sort()) {
    const tot = Object.values(treeState[e]).reduce((a,b)=>a+b,0);
    html += `<div class="tree-node tree-ext">${getIcon(e)} ${e}/<span class="tree-count"> (${tot})</span></div>`;
    for (const [s,c] of Object.entries(treeState[e]).sort((a,b)=>b[1]-a[1]))
      html += `<div class="tree-node tree-sub">${s}<span class="tree-count"> ${c}</span></div>`;
  }
  out.innerHTML = html || '<div style="color:var(--muted);font-style:italic;font-size:11px">Building…</div>';
}

