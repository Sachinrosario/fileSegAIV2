// MAIN SEGREGATION ENGINE
// ══════════════════════════════════════════════════════════════════════════════
async function startSegregate() {
  if (!destHandle){alert('Please select a destination folder.');return;}
  const aiOn  = document.getElementById('aiToggle').checked;
  const isPro = document.getElementById('tierToggle').checked;
  const prov  = document.getElementById('aiProvider').value;
  if (aiOn && !document.getElementById('apiKeyInput').value.trim()){alert('API key required.');return;}

  document.getElementById('goBtn').disabled=true;
  document.getElementById('logPanel').classList.add('on');
  document.getElementById('doneBanner').classList.remove('on');
  document.getElementById('logOut').innerHTML='';
  document.getElementById('treeOut').innerHTML='';
  subCatMemory={}; treeState={}; totalMerges=0; totalErrors=0;
  notifiedThresholds.clear(); sessionLogReport=[];
  ['sbMerges','sbErrors'].forEach(id=>document.getElementById(id).textContent='0');
  document.getElementById('sbAiCalls').textContent='0';

  sessionLogReport.push(`FILE SEGREGATOR AI — REPORT\nDate: ${new Date().toLocaleString()}\nMode: ${aiOn?`AI (${prov} ${isPro?'PRO':'FREE'})`:'Extension Only'}\nDest: ${destHandle.name}\n${'─'.repeat(60)}\n`);

  setStatus('on','PROCESSING');sbSet('copy','PROCESSING');sbStartTimer();
  document.getElementById('badge1').classList.add('active');

  const extDirCache={}, subDirCache={};
  let done=0, aiCalls=0;
  const limitObj = API_LIMITS[prov][isPro?'pro':'free'];
  const reqDelay = (aiOn && !isPro) ? Math.ceil((60/limitObj.rpm)*1000) : 0;

  log('info',`Parsers — PDF.js:${typeof pdfjsLib!=='undefined'?'✓':'✗'} mammoth:${typeof mammoth!=='undefined'?'✓':'✗'} SheetJS:${typeof XLSX!=='undefined'?'✓':'✗'}`);
  log('info',`Mode: ${aiOn?prov.toUpperCase()+' AI':'EXTENSION ONLY'} | Throttle: ${reqDelay}ms | Concurrency: ${aiOn?(isPro?5:1):25}`);

  const processFile = async (f) => {
    const ext    = (f.name.includes('.') ? f.name.split('.').pop() : '').toLowerCase();
    const extKey = ext ? ext.toUpperCase() : 'NO_EXTENSION';

    if (!extDirCache[extKey]) {
      try { extDirCache[extKey] = await getOrCreateDir(destHandle, extKey); }
      catch(e){ totalErrors++;log('err',`Cannot create ${extKey}/`);sbUpdate(done,allFiles.length,totalErrors);return; }
    }
    const extDir = extDirCache[extKey];
    let subcat = null;

    if (aiOn) {
      sbSet('classify','PARSING'); sbAct('📖',`Parsing: ${f.name}`,true);
      try {
        // ── REAL CONTENT EXTRACTION ──
        const content = await extractFileContent(f, isPro);
        log('info', `  ↳ ${content.method}`);

        sbSet('classify','AI CLASSIFY'); sbAct('🤖',`Classifying: ${f.name}`,true);
        const aiSuggestion = await classifyFile(f, extKey, content);
        aiCalls++;
        document.getElementById('sbAiCalls').textContent = aiCalls;

        // Dedup
        subcat = resolveCategory(aiSuggestion, extKey);
        log('lai', `${f.name}  →  ${extKey}/${subcat}${aiSuggestion!==subcat?`  [AI proposed: "${aiSuggestion}"]`:''}`);
        sessionLogReport.push(`[OK] ${f.webkitRelativePath}  →  /${extKey}/${subcat}/${f.name}`+(aiSuggestion!==subcat?` (merged from "${aiSuggestion}")`:''));

        // Quota alert
        const pct=(aiCalls/limitObj.rpd)*100;
        for(const th of ALERT_THRESHOLDS){
          if(pct>=th&&!notifiedThresholds.has(th)){
            notifiedThresholds.add(th);
            showToast(`Used <strong>${th}%</strong> of daily quota (${aiCalls}/${limitObj.rpd})`,'warn');
          }
        }
        if(reqDelay>0) await sleep(reqDelay);

      } catch(e) {
        subcat='Unrouted';
        log('warn',`AI failed for ${f.name}: ${e.message} → Unrouted`);
        sessionLogReport.push(`[WARN] ${f.webkitRelativePath}  →  AI failed → /Unrouted/`);
      }

      const key = `${extKey}::${subcat}`;
      if (!subDirCache[key]) {
        try { subDirCache[key] = await getOrCreateDir(extDir, subcat); }
        catch(e){ subDirCache[key] = await getOrCreateDir(extDir,'Unrouted'); subcat='Unrouted'; }
      }
    }

    const targetDir = aiOn ? subDirCache[`${extKey}::${subcat}`] : extDir;
    sbSet(aiOn?'classify':'copy','WRITING');

    try {
      const written = await safeWrite(targetDir, f);
      done++;
      const pct = Math.round((done/allFiles.length)*100);
      document.getElementById('pb').style.width = pct+'%';
      document.getElementById('ppct').textContent = pct+'%';
      treeAdd(extKey, aiOn ? subcat : '(extension only)');
      if(!aiOn){ log('ok',`/${extKey}/${written}`); sessionLogReport.push(`[OK] ${f.webkitRelativePath}  →  /${extKey}/${written}`); }
      sbUpdate(done,allFiles.length,totalErrors);
    } catch(e) {
      totalErrors++;
      log('err',`Write failed: ${f.name}: ${e.message}`);
      sessionLogReport.push(`[ERROR] ${f.webkitRelativePath}  →  ${e.message}`);
      sbUpdate(done,allFiles.length,totalErrors);
    }
  };

  const CONC = aiOn ? (isPro?5:1) : 25;
  await processBatch(allFiles, CONC, processFile);

  // Write report
  try {
    sessionLogReport.push(`\n${'─'.repeat(60)}\nSUMMARY\nFiles: ${done} | Errors: ${totalErrors} | AI calls: ${aiCalls} | Merges: ${totalMerges}\n\nFOLDER STRUCTURE:`);
    for(const[e,cats]of Object.entries(subCatMemory)){
      sessionLogReport.push(`  ${e}/`);
      cats.forEach(c=>sessionLogReport.push(`    └─ ${c.name}/ (${c.count} files)`));
    }
    const rh = await destHandle.getFileHandle('Segregation_Report.txt',{create:true});
    const rw = await rh.createWritable();
    await rw.write(sessionLogReport.join('\n'));
    await rw.close();
    log('info','📄 Segregation_Report.txt written to destination.');
  } catch(e){log('warn','Could not write report: '+e.message);}

  document.getElementById('badge2').classList.add('active');
  const banner = totalErrors
    ? `⚠ DONE — ${done} copied · ${totalErrors} failed · ${totalMerges} merges`
    : `✓ COMPLETE — ${done} files · ${totalMerges} folder merges · ${aiCalls} AI calls`;
  document.getElementById('doneBanner').textContent = banner;
  document.getElementById('doneBanner').classList.add('on');
  setStatus('on', totalErrors?'ERRORS':'COMPLETE');
  sbStopTimer(); sbSet('done','COMPLETE'); sbAct('✓','Segregation complete',false);
  document.getElementById('goBtn').disabled = false;
}

