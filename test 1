function getCat(f){const e=f.includes('.')?f.split('.').pop().toLowerCase():'';return e?e.toUpperCase():'NO_EXTENSION';}
function getIcon(e){return EXT_META[e.toLowerCase()]||'📦';}
function fmtSize(b){if(b<1024)return b+' B';if(b<1048576)return(b/1024).toFixed(1)+' KB';if(b<1073741824)return(b/1048576).toFixed(1)+' MB';return(b/1073741824).toFixed(2)+' GB';}
function log(t,m){const o=document.getElementById('logOut'),d=document.createElement('div');d.className='lline';const ic={ok:'✓',err:'✗',info:'·',warn:'⚠',lai:'🤖',merge:'⇢'};d.innerHTML=`<span class="ltime">[${new Date().toTimeString().slice(0,8)}]</span><span class="l${t}">${ic[t]||'·'}</span><span class="lmsg">${esc(m)}</span>`;o.appendChild(d);o.scrollTop=o.scrollHeight;}
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function setStatus(c,t){document.getElementById('sdot').className='sdot'+(c?' '+c:'');document.getElementById('stxt').textContent=t;}
function sbSet(s,l){document.getElementById('sbDot').className=`sb-dot ${s}`;document.getElementById('sbLabel').className=`sb-plabel ${s}`;document.getElementById('sbLabel').textContent=l;}
function sbAct(i,t,a){document.getElementById('sbIcon').textContent=i;document.getElementById('sbText').textContent=t;document.getElementById('sbText').className='sb-act-text'+(a?' active':'');}
